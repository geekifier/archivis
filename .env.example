# Archivis Configuration
# Copy this file to .env and modify as needed.
# These variables are used by docker-compose.yml.

# Port to expose on the host (maps to container port 9514)
ARCHIVIS_PORT=9514

# Log level: trace, debug, info, warn, error
ARCHIVIS_LOG_LEVEL=info

# Host path for book storage (bind mount into the container)
# BOOK_STORAGE_PATH=./books
